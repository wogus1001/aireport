# =============================================================
# 내일사장 상권분석 AI — 환경변수 예시
# 이 파일을 복사해서 .env.local을 만들고 실제 값을 입력하세요.
# cp .env.local.example .env.local
# =============================================================

# ---------------------------
# Gemini AI (필수)
# 발급: https://aistudio.google.com → Get API Key
# ---------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_CHAT_MODEL=gemini-2.5-flash

# ---------------------------
# 카카오 로컬 API (필수 — 주소 지오코딩)
# 발급: https://developers.kakao.com → 내 애플리케이션 → REST API 키
# NEXT_PUBLIC_ prefix: 브라우저 노출 허용
# ---------------------------
NEXT_PUBLIC_KAKAO_REST_API_KEY=

# ---------------------------
# 통계청 SGIS (선택 — 인구통계)
# 발급: https://sgisapi.kostat.go.kr → 회원가입 후 Consumer Key/Secret 발급
# ---------------------------
SGIS_CONSUMER_KEY=
SGIS_CONSUMER_SECRET=

# ---------------------------
# 서울시 공공데이터 (선택 — 서울 상권 데이터)
# 발급: https://data.seoul.go.kr → 인증키 발급
# ---------------------------
SEOUL_API_KEY=

# ---------------------------
# 경기도 공공데이터 (선택 — 경기도 상권 데이터)
# 발급: https://data.gg.go.kr → 인증키 발급
# ---------------------------
GYEONGGI_API_KEY=

# ---------------------------
# 공공데이터포털 (선택 — 소상공인 상가 정보)
# 발급: https://www.data.go.kr → 마이페이지 → 인증키
# ---------------------------
DATA_GO_KR_API_KEY=

# ---------------------------
# 네이버 데이터랩 (선택 — 검색 트렌드)
# 발급: https://developers.naver.com → 애플리케이션 등록 → Client ID/Secret
# ---------------------------
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ---------------------------
# Spring Boot 백엔드 URL
# 로컬: http://localhost:8080
# 프로덕션: Railway/EC2 배포 후 URL로 변경
# ---------------------------
SPRING_BOOT_URL=http://localhost:8080

# ---------------------------
# 서비스 기본 URL (리포트 URL 생성에 사용)
# 로컬: http://localhost:3000
# 프로덕션: https://nsajang.com
# ---------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
